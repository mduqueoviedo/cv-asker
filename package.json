    "packageManager": {
      "name": "pnpm",
      "version": "11.2.2",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "@tailwindcss/cli": "^4.3.2",
