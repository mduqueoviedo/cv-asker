{
  "name": "cv-asker",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:resume-styles": "./node_modules/.bin/tailwindcss -i ./src/services/resumes/templates/aurora-split.css -o ./src/services/resumes/templates/aurora-split.generated.css --minify",
    "copy:resume-assets": "node ./scripts/copy-resume-assets.mjs",
    "dev": "./node_modules/.bin/tailwindcss -i ./src/services/resumes/templates/aurora-split.css -o ./src/services/resumes/templates/aurora-split.generated.css --minify && tsx watch src/index.ts",
    "build": "./node_modules/.bin/tailwindcss -i ./src/services/resumes/templates/aurora-split.css -o ./src/services/resumes/templates/aurora-split.generated.css --minify && tsc && node ./scripts/copy-resume-assets.mjs",
    "generate:resumes": "./node_modules/.bin/tailwindcss -i ./src/services/resumes/templates/aurora-split.css -o ./src/services/resumes/templates/aurora-split.generated.css --minify && tsx src/scripts/smoke-generate-resumes.ts --count 25 --mode replace --language es-ES --template aurora-split",
    "generate:resumes:en": "./node_modules/.bin/tailwindcss -i ./src/services/resumes/templates/aurora-split.css -o ./src/services/resumes/templates/aurora-split.generated.css --minify && tsx src/scripts/smoke-generate-resumes.ts --count 25 --mode replace --language en --template aurora-split",
    "generate:resumes:append": "./node_modules/.bin/tailwindcss -i ./src/services/resumes/templates/aurora-split.css -o ./src/services/resumes/templates/aurora-split.generated.css --minify && tsx src/scripts/smoke-generate-resumes.ts --count 25 --mode append --language es-ES --template aurora-split",
    "smoke:resumes": "./node_modules/.bin/tailwindcss -i ./src/services/resumes/templates/aurora-split.css -o ./src/services/resumes/templates/aurora-split.generated.css --minify && tsx src/scripts/smoke-generate-resumes.ts"
  },
