{
  "name": "cv-asker",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:resume-styles": "node ./scripts/build-resume-styles.mjs",
    "copy:resume-assets": "node ./scripts/copy-resume-assets.mjs",
    "dev": "node ./scripts/build-resume-styles.mjs && tsx watch src/index.ts",
    "build": "node ./scripts/build-resume-styles.mjs && tsc && node ./scripts/copy-resume-assets.mjs",
    "generate": "node ./scripts/build-resume-styles.mjs && tsx src/scripts/smoke-generate-resumes.ts",
    "extract:text": "node --import tsx src/scripts/smoke-extract-resume-text.ts",
    "extract:text:file": "node --import tsx src/scripts/smoke-extract-resume-file.ts",
    "rag:index": "node --import tsx src/scripts/smoke-build-rag-index.ts",
    "rag:ask": "node --import tsx src/scripts/smoke-ask-rag.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.2.2",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "@tailwindcss/cli": "^4.3.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "puppeteer": "^25.3.0",
    "tailwindcss": "^4.3.2"
  }
}
