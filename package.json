{
  "name": "cv-asker",
  "version": "1.0.0",
  "private": true,
  "description": "Local-first CV screening prototype with resume generation, ingestion, and chat.",
  "scripts": {
    "build:resume-styles": "node ./apps/api/scripts/build-resume-styles.mjs",
    "copy:resume-assets": "node ./apps/api/scripts/copy-resume-assets.mjs",
    "dev:api": "tsx watch apps/api/src/server.ts",
    "dev:chat": "vite build --watch --config apps/chat/vite.config.ts",
    "dev": "pnpm build:resume-styles && concurrently -k -n chat,api -c blue,green \"pnpm dev:chat\" \"pnpm dev:api\"",
    "build:api": "pnpm build:resume-styles && tsc -p apps/api/tsconfig.json && pnpm copy:resume-assets",
    "build:chat": "vite build --config apps/chat/vite.config.ts",
    "build": "pnpm build:chat && pnpm build:api",
    "typecheck:api": "tsc -p apps/api/tsconfig.json --noEmit",
    "typecheck:chat": "tsc -p apps/chat/tsconfig.json --noEmit",
    "typecheck": "pnpm typecheck:chat && pnpm typecheck:api",
    "smoke:generate": "pnpm build:resume-styles && tsx apps/api/src/testing/smoke/generate-resumes.smoke.ts",
    "smoke:extract": "node --import tsx apps/api/src/testing/smoke/extract-resume-text.smoke.ts",
    "smoke:extract:file": "node --import tsx apps/api/src/testing/smoke/extract-resume-file.smoke.ts",
    "smoke:index": "node --import tsx apps/api/src/testing/smoke/build-rag-index.smoke.ts",
    "smoke:ask": "node --import tsx apps/api/src/testing/smoke/ask-rag.smoke.ts",
    "smoke:http": "node --import tsx apps/api/src/testing/smoke/http-integration.smoke.ts",
    "test:smoke": "node --import tsx apps/api/src/testing/smoke/run-smoke-suite.ts",
    "test:smoke:http": "node --import tsx apps/api/src/testing/smoke/run-smoke-suite.ts --http",
    "test:smoke:ai": "node --import tsx apps/api/src/testing/smoke/run-smoke-suite.ts --ai",
    "test:smoke:full": "node --import tsx apps/api/src/testing/smoke/run-smoke-suite.ts --full",
    "generate": "pnpm smoke:generate",
    "extract:text": "pnpm smoke:extract",
    "extract:text:file": "pnpm smoke:extract:file",
    "rag:index": "pnpm smoke:index",
    "rag:ask": "pnpm smoke:ask",
    "rag:http": "pnpm smoke:http"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.2.2",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "concurrently": "^10.0.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  },
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "@tailwindcss/cli": "^4.3.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "puppeteer": "^25.3.0",
    "tailwindcss": "^4.3.2"
  }
}
