PORT=3000
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODELS=google/gemini-2.5-flash-lite,google/gemma-3-27b-it:free,openai/gpt-oss-20b:free
# Optional legacy single-model override. Ignored when OPENROUTER_MODELS is set.
# OPENROUTER_MODEL=google/gemini-2.5-flash-lite
AI_REQUEST_TIMEOUT_MS=20000
AI_REQUEST_MAX_RETRIES=2
AI_REQUEST_BASE_DELAY_MS=600
AI_COMPLETION_MAX_TOKENS=600
RESUME_TEXT_BATCH_SIZE=2
RESUME_DEFAULT_LANGUAGE=en
